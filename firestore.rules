rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidUserStats(data) {
      return data.keys().hasAll(['inventory', 'totalPower']) &&
             data.totalPower is number &&
             data.inventory is list &&
             (!data.keys().hasAny(['questStage']) || data.questStage is number) &&
             (!data.keys().hasAny(['epicFishesCaught']) || data.epicFishesCaught is number) &&
             (!data.keys().hasAny(['mythicFishesReleased']) || data.mythicFishesReleased is number);
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUserStats(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUserStats(request.resource.data);
    }
  }
}
